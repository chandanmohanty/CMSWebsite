# Production public config, used by `next build`.
# NEXT_PUBLIC_* values are inlined into the client bundle, so these are not
# secrets. Committed so a server-side build (Hostinger) produces a correctly
# configured app without needing build-time env injection.
# Local development is unaffected: .env.local takes precedence.
NEXT_PUBLIC_API_URL=https://api.athithi24.com
NEXT_PUBLIC_SITE_DOMAIN=athithi24.com
NEXT_PUBLIC_SITE_SLUG=
